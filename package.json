{
  "name": "node-terminal",
  "version": "0.2.0",
  "description": "node-based terminal manager — multiple draggable, zoomable terminals on a single canvas.",
  "author": "enes",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:unit": "vitest run test/remote",
    "rebuild": "electron-rebuild -f -w node-pty",
    "make-icon": "node scripts/make-icon.mjs",
    "make-social": "node scripts/make-social.mjs",
    "dist": "npm run make-icon && electron-vite build && electron-builder --mac --arm64 -c.mac.identity=null -c.mac.notarize=false",
    "release": "npm run make-icon && electron-vite build && electron-builder --mac --arm64 --x64",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.nodeterm.app",
    "productName": "nodeterm",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "generic",
      "url": "https://nodeterm.dev/updates"
    }
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "marked": "^12.0.2",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.0.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.21.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.3.0",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
